diff --git a/supabase/migrations/017_menu_item_option_type.sql b/supabase/migrations/017_menu_item_option_type.sql
new file mode 100644
index 0000000..fd12b87
--- /dev/null
+++ b/supabase/migrations/017_menu_item_option_type.sql
@@ -0,0 +1,9 @@
+-- Add option_type column to distinguish between size variants and extras
+-- 'size' = mutually exclusive variant (e.g. Pequeña, Mediana, Grande) — price replaces base price
+-- 'extra' = additive complement (e.g. queso extra, tocino) — price adds to base/size price
+
+ALTER TABLE menu_item_options
+  ADD COLUMN IF NOT EXISTS option_type TEXT NOT NULL DEFAULT 'size'
+  CHECK (option_type IN ('size', 'extra'));
+
+COMMENT ON COLUMN menu_item_options.option_type IS 'size = exclusive variant (radio), extra = additive complement (checkbox)';
